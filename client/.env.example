# Client environment template.
# Copy this to `.env.local` and adjust if your backend runs elsewhere.
# These are read by client/src/config/env.ts.

# Base URL of the backend HTTP API (no trailing slash).
VITE_API_URL=http://localhost:3000/api

# Base URL of the backend Socket.IO server.
VITE_SOCKET_URL=http://localhost:3000
